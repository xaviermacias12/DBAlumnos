@page
@model DBAlumnos.Pages.MateriasCrearModel
@{
    ViewData["Title"] = "Crear Materia";
}

<div class="container">
    <h2 class="page-title">Crear Nueva Materia</h2>

    <div class="form-container">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Materia.Nombre" class="form-label">Nombre de la Materia:</label>
                <input asp-for="Materia.Nombre" class="form-control" required />
                <span asp-validation-for="Materia.Nombre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Materia.Creditos" class="form-label">Créditos:</label>
                <input asp-for="Materia.Creditos" class="form-control" type="number" min="1" max="10" required />
                <span asp-validation-for="Materia.Creditos" class="text-danger"></span>
            </div>

            <div class="action-bar">
                <button type="submit" class="btn-save">Guardar Materia</button>
                <a asp-page="/MateriasIndex" class="btn-cancel">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}