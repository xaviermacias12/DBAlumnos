@page
@model DBAlumnos.Pages.IndexModel
@{
    ViewData["Title"] = "Lista de Alumnos";
}

<div class="container">
    <h2 class="page-title">Lista de Alumnos</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="table-container">
        <table class="styled-table">
            <thead>
            <th>ID</th>
            <th>Nombre</th>
            <th>Carrera</th>
            <th>Semestre</th>
            <th>Correo</th>
            <th>Teléfono</th>
            <th>Fecha Nacimiento</th>
            <th style="min-width: 280px;">Acciones</th>
            </thead>
            <tbody>
                @foreach (var alumno in Model.ListaAlumnos)
                {
                    <tr>
                        <td>@alumno.Id</td>
                        <td>@alumno.Nombre</td>
                        <td>@alumno.Carrera</td>
                        <td>@alumno.Semestre</td>
                        <td>@alumno.Correo</td>
                        <td>@alumno.Telefono</td>
                        <td>@(alumno.FechaNacimiento.Year > 1 ? alumno.FechaNacimiento.ToShortDateString() : "No registrada")</td>
                        <td class="actions">
                            <a asp-page="/VerInfo" asp-route-id="@alumno.Id" class="btn-details">Ver Detalles</a>
                            <a asp-page="/VerDetalles" asp-route-id="@alumno.Id" class="btn-subjects">Ver Materias</a>
                            <a asp-page="/EditarAlumno" asp-route-id="@alumno.Id" class="btn-edit">Editar</a>
                            <a asp-page="/EliminarAlumno" asp-route-id="@alumno.Id" class="btn-delete">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>