@page
@model DBAlumnos.Pages.IndexModel
@{
    ViewData["Title"] = "Lista de Alumnos";
}

<div class="container">
    <h2 class="page-title">Lista de Alumnos</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- BUSCADOR -->
    <div class="search-container">
        <form method="get" class="search-form">
            <div class="search-box">
                <input type="text" 
                       name="searchTerm" 
                       id="searchTerm" 
                       class="search-input" 
                       placeholder="Buscar por nombre, carrera o correo..."
                       value="@Model.SearchTerm" />
                <button type="submit" class="btn-search">Buscar</button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a asp-page="/Index" class="btn-clear">Limpiar</a>
                }
            </div>
        </form>
    </div>

    <div class="table-container">
        <table class="styled-table">
            <thead>
                    <th>Foto</th>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Carrera</th>
                    <th>Semestre</th>
                    <th>Correo</th>
                    <th>Teléfono</th>
                    <th>Fecha Nacimiento</th>
                    <th>Acciones</th>
                </thead>
            <tbody>
                @if (Model.ListaAlumnos != null && Model.ListaAlumnos.Any())
                {
                    @foreach (var alumno in Model.ListaAlumnos)
                    {
                        <tr>
                            <td class="foto-cell">
                                @if (!string.IsNullOrEmpty(alumno.FotoUrl))
                                {
                                    <img src="@alumno.FotoUrl" alt="Foto" class="foto-miniatura" />
                                }
                                else
                                {
                                    <img src="/uploads/alumnos/default.png" alt="Sin foto" class="foto-miniatura" />
                                }
                            </td>
                            <td>@alumno.Id</td>
                            <td>@alumno.Nombre</td>
                            <td>@alumno.Carrera</td>
                            <td>@alumno.Semestre</td>
                            <td>@alumno.Correo</td>
                            <td>@alumno.Telefono</td>
                            <td>@alumno.FechaNacimiento.ToShortDateString()</td>
                            <td class="actions">
                                <a asp-page="/VerInfo" asp-route-id="@alumno.Id" class="btn-details">Ver Detalles</a>
                                <a asp-page="/VerDetalles" asp-route-id="@alumno.Id" class="btn-subjects">Ver Materias</a>
                                <a asp-page="/EditarAlumno" asp-route-id="@alumno.Id" class="btn-edit">Editar</a>
                                <a asp-page="/EliminarAlumno" asp-route-id="@alumno.Id" class="btn-delete">Eliminar</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" style="text-align: center; padding: 40px;">
                            @if (!string.IsNullOrEmpty(Model.SearchTerm))
                            {
                                <span>No se encontraron alumnos que coincidan con "<strong>@Model.SearchTerm</strong>"</span>
                                <br />
                            }
                            else
                            {
                                <span>No hay alumnos registrados</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>