@page "{id:int}"
@model DBAlumnos.Pages.EliminarAlumnoModel
@{
    ViewData["Title"] = "Eliminar Alumno";
}

<div class="container">
    <h2 class="page-title">Eliminar Alumno</h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="delete-warning">
        <p class="warning-text">¿Estás seguro de eliminar este alumno?</p>
        <p class="warning-subtext">Esta acción no se puede deshacer y eliminará todas sus relaciones con materias.</p>
    </div>

    <div class="delete-info">
        <div class="info-card" style="display: flex; gap: 30px; align-items: flex-start;">
            <div style="text-align: center;">
                @if (!string.IsNullOrEmpty(Model.Alumno.FotoUrl))
                {
                    <img src="@Model.Alumno.FotoUrl" alt="Foto" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid #dc3545;" />
                }
                else
                {
                    <img src="/uploads/alumnos/default.png" alt="Sin foto" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid #dc3545;" />
                }
            </div>
            <div style="flex: 1;">
                <div class="info-row">
                    <span class="info-label"><strong>ID:</strong></span>
                    <span class="info-value">@Model.Alumno.Id</span>
                </div>
                <div class="info-row">
                    <span class="info-label"><strong>Nombre:</strong></span>
                    <span class="info-value">@Model.Alumno.Nombre</span>
                </div>
                <div class="info-row">
                    <span class="info-label"><strong>Carrera:</strong></span>
                    <span class="info-value">@Model.Alumno.Carrera</span>
                </div>
                <div class="info-row">
                    <span class="info-label"><strong>Semestre:</strong></span>
                    <span class="info-value">@Model.Alumno.Semestre</span>
                </div>
                <div class="info-row">
                    <span class="info-label"><strong>Correo:</strong></span>
                    <span class="info-value">@Model.Alumno.Correo</span>
                </div>
                <div class="info-row">
                    <span class="info-label"><strong>Teléfono:</strong></span>
                    <span class="info-value">@Model.Alumno.Telefono</span>
                </div>
                <div class="info-row">
                    <span class="info-label"><strong>Fecha Nacimiento:</strong></span>
                    <span class="info-value">@Model.Alumno.FechaNacimiento.ToShortDateString()</span>
                </div>
            </div>
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Alumno.Id" />
        <input type="hidden" asp-for="Alumno.Nombre" />
        <input type="hidden" asp-for="Alumno.Carrera" />
        <input type="hidden" asp-for="Alumno.Semestre" />
        <input type="hidden" asp-for="Alumno.Correo" />
        <input type="hidden" asp-for="Alumno.Telefono" />
        <input type="hidden" asp-for="Alumno.FechaNacimiento" />
        <input type="hidden" asp-for="Alumno.FotoUrl" />

        <div class="form-actions delete-actions">
            <button type="submit" class="btn-delete-confirm">Sí, Eliminar Alumno</button>
            <a asp-page="/Index" class="btn-cancel">Cancelar</a>
        </div>
    </form>
</div>