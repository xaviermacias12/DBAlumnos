@page "{id:int}"
@model DBAlumnos.Pages.MateriasEliminarModel
@{
    ViewData["Title"] = "Eliminar Materia";
}

<div class="container">
    <h2 class="page-title">Eliminar Materia</h2>

    @if (Model.TieneRelaciones)
    {
        <div class="alert alert-warning">
            <p><strong>No se puede eliminar esta materia</strong></p>
            <p>La materia <strong>"@Model.Materia.Nombre"</strong> está siendo cursada por los siguientes alumnos:</p>

            <ul style="margin-top: 10px; margin-left: 20px;">
                @foreach (var alumno in Model.AlumnosRelacionados)
                {
                    <li>@alumno.Nombre - @alumno.Carrera (Semestre @alumno.Semestre)</li>
                }
            </ul>

            <p style="margin-top: 15px;">Primero debes eliminar las relaciones de esta materia con los alumnos.</p>
        </div>

        <div class="action-bar">
            <a asp-page="/MateriasIndex" class="btn-back">Volver</a>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <p>¿Estás seguro de que deseas eliminar la materia <strong>"@Model.Materia.Nombre"</strong>?</p>
            <p>Esta acción no se puede deshacer.</p>
        </div>

        <div class="info-card">
            <div class="info-row">
                <strong>ID:</strong> <span>@Model.Materia.Id</span>
            </div>
            <div class="info-row">
                <strong>Nombre:</strong> <span>@Model.Materia.Nombre</span>
            </div>
            <div class="info-row">
                <strong>Créditos:</strong> <span>@Model.Materia.Creditos</span>
            </div>
        </div>

        <div class="action-bar">
            <form method="post">
                <button type="submit" class="btn-delete-confirm">Sí, Eliminar Materia</button>
                <a asp-page="/MateriasIndex" class="btn-cancel">Cancelar</a>
            </form>
        </div>
    }
</div>