@page
@model DBAlumnos.Pages.AlumnoMateriasModel
@{
    ViewData["Title"] = "Relación Alumno - Materias";
}

<div class="container">
    <h2 class="page-title">Relación Alumno - Materias</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="table-container">
        <table class="styled-table">
            <thead>
            <th>Alumno</th>
            <th>Materia</th>
            <th>Acciones</th>
            </thead>
            <tbody>
                @if (Model.Lista != null && Model.Lista.Any())
                {
                    @foreach (var item in Model.Lista)
                    {
                        <tr>
                            <td style="width: 40%;">@item.Alumno?.Nombre</td>
                            <td style="width: 40%;">@item.Materia?.Nombre</td>
                            <td class="actions" style="width: 20%;">
                                <a asp-page="/EliminarRelacion"
                                   asp-route-alumnoId="@item.AlumnoId"
                                   asp-route-materiaId="@item.MateriaId"
                                   class="btn-delete">
                                    Eliminar
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" style="text-align: center;">No hay relaciones registradas</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>